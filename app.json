{
  "expo": {
    "name": "Ravenwood",
    "slug": "ravenwood",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "ravenwood",
    "splash": {
      "backgroundColor": "#0B0E13",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "cloud.paim.ravenwood"
    },
    "android": {
      "package": "cloud.paim.ravenwood"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-audio",
      "expo-web-browser"
    ]
  }
}
